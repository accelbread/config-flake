{ pkgs, lib, ... }:
let
  use-ccache = false;
  stdenv = llvmStdenv pkgs.llvmPackages;
  base-kernel = pkgs.linux;

  llvmStdenv = llvmPackages:
    let inherit (llvmPackages) stdenv bintools; in
    pkgs.overrideCC stdenv (stdenv.cc.override { inherit bintools; });
