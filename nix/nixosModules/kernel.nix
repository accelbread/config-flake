          INPUT = yes;
          INPUT_KEYBOARD = yes;
          IPV6 = yes;
          IPV6_MULTIPLE_TABLES = yes;
          IP_MULTICAST = yes;
          IP_MULTIPLE_TABLES = yes;
          KCMP = yes;
          KERNEL_ZSTD = yes;
          LRU_GEN = yes;
          LRU_GEN_ENABLED = yes;
