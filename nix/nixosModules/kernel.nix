          NET_SCH_FQ_CODEL = yes;
          NF_TABLES_INET = yes;
          NF_TABLES_IPV4 = yes;
          NF_TABLES_IPV6 = yes;
          NVME_HWMON = yes;
          PCIEAER = yes;
          POSIX_MQUEUE = yes;
          PROC_FS = yes;
          RTC_HCTOSYS = yes;
          RT_GROUP_SCHED = no;
          SCHED_CORE = yes;
          SECCOMP = yes;
          SECCOMP_FILTER = yes;
          SECURITY = yes;
          SECURITY_LANDLOCK = yes;
          SIGNALFD = yes;
          SPI = yes;
          SYSFS = yes;
          SYSVIPC = yes;
          THERMAL = yes;
          THERMAL_HWMON = yes;
